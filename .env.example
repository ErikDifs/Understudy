# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Public URL this app is reachable at — Recall.ai's webhook/realtime callbacks
# need to reach it, so for local dev this must be a tunnel (e.g. ngrok), not localhost.
PUBLIC_BASE_URL=""

# Recall.ai (https://www.recall.ai/) — meeting bot API
RECALL_API_KEY=""
RECALL_REGION="us-east-1"
RECALL_WEBHOOK_SECRET="whsec_..."

# Anthropic (https://console.anthropic.com/) — meeting summarization
ANTHROPIC_API_KEY=""
